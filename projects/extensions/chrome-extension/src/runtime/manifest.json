{
  "manifest_version": 3,
  "name": "Readplace — Save Articles & Read Later",
  "version": "1.0.108",
  "description": "Save articles with one click. A privacy-first read-it-later app and Pocket alternative.",
  "permissions": [
    "activeTab",
    "tabs",
    "contextMenus",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://readplace.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.template.html",
    "default_title": "Readplace",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "64": "icons/icon-64.png"
    }
  },
  "background": {
    "service_worker": "background/background.browser.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/shortcut.browser.js"
      ],
      "run_at": "document_start"
    }
  ]
}
