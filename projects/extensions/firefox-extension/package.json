{
  "name": "firefox-extension",
  "version": "0.0.0-managed-by-tag",
  "description": "Readplace — Where reading still matters",
  "main": "src/infra/index.ts",
  "private": true,
  "scripts": {
    "compile": "tsc && EXTENSION_VERSION=\"${EXTENSION_VERSION:-0.0.0}\" HUTCH_SERVER_URL=https://readplace.com node scripts/build-extension.js",
    "compile-dev": "tsc && HUTCH_SERVER_URL=http://127.0.0.1:3000 node scripts/build-extension.js",
    "sign": "web-ext sign --channel=unlisted --source-dir dist-extension-compiled --artifacts-dir /tmp/ext-sign-submit --upload-source-code /tmp/extension-source.zip --api-key=\"$AMO_JWT_ISSUER\" --api-secret=\"$AMO_JWT_SECRET\" --approval-timeout 0",
    "check-unused-css": "node scripts/check-unused-css.js",
    "lint": "tsc --project tsconfig.lint.json && concurrently --kill-others-on-fail \"biome lint src\" \"knip\" \"pnpm check-unused-css\"",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000 --passWithNoTests",
    "test:sequential": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000 --runInBand --passWithNoTests",
    "test-with-coverage": "c8 node scripts/run-tests-with-coverage.js && node enforce-coverage.config.js",
    "test:e2e": "E2E_PORT=3000 HUTCH_SERVER_URL=http://127.0.0.1:3000 node scripts/build-extension.js && E2E_PORT=3000 node --test dist/e2e/login-flow/run.e2e-local.main.js",
    "test:e2e:pdf-save-staging": "node --test dist/e2e/pdf-save-flow/run.e2e-staging.main.js",
    "deploy-infra": "nx run deploy-infra",
    "post-deploy": "nx run firefox-extension:post-deploy",
    "check-infra": "PULUMI_CONFIG_PASSPHRASE='' pulumi preview --stack \"${PULUMI_STACK:?PULUMI_STACK is not set}\"",
    "check": "nx run firefox-extension:check",
    "ext:run": "EXTENSION_VERSION=\"${EXTENSION_VERSION:-0.0.0}\" HUTCH_SERVER_URL=https://readplace.com node scripts/build-extension.js && web-ext run --source-dir dist-extension-compiled"
  },
  "dependencies": {
    "browser-extension-core": "workspace:*",
    "@packages/hutch-infra-components": "workspace:*",
    "@packages/hutch-logger": "workspace:*",
    "@packages/onboarding-extension-signal": "workspace:*"
  },
  "devDependencies": {
    "@packages/test-phase-runner": "workspace:*",
    "@pulumi/aws": "7.20.0",
    "@pulumi/pulumi": "3.224.0",
    "@types/jest": "29.5.14",
    "@types/selenium-webdriver": "4.35.5",
    "c8": "10.1.3",
    "concurrently": "9.2.1",
    "jest": "29.7.0",
    "@packages/check-unused-css": "workspace:*",
    "selenium-webdriver": "4.41.0",
    "typescript": "5.9.3",
    "web-ext": "9.3.0"
  }
}
