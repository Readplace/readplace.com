{
  "name": "hutch",
  "version": "1.0.0",
  "description": "Readplace — read-it-later web application",
  "main": "src/infra/index.ts",
  "exports": {
    ".": "./src/infra/index.ts",
    "./test-app": {
      "types": "./dist/runtime/test-app.d.ts",
      "default": "./dist/runtime/test-app.js"
    },
    "./test-app-fakes": {
      "types": "./dist/runtime/test-app-fakes.d.ts",
      "default": "./dist/runtime/test-app-fakes.js"
    },
    "./in-memory-article-store": {
      "types": "./dist/runtime/providers/article-store/in-memory-article-store.d.ts",
      "default": "./dist/runtime/providers/article-store/in-memory-article-store.js"
    },
    "./in-memory-article-crawl": {
      "types": "./dist/runtime/providers/article-crawl/in-memory-article-crawl.d.ts",
      "default": "./dist/runtime/providers/article-crawl/in-memory-article-crawl.js"
    }
  },
  "typesVersions": {
    "*": {
      "test-app": [
        "./dist/runtime/test-app.d.ts"
      ],
      "test-app-fakes": [
        "./dist/runtime/test-app-fakes.d.ts"
      ],
      "in-memory-article-store": [
        "./dist/runtime/providers/article-store/in-memory-article-store.d.ts"
      ],
      "in-memory-article-crawl": [
        "./dist/runtime/providers/article-crawl/in-memory-article-crawl.d.ts"
      ]
    }
  },
  "scripts": {
    "start": "NODE_ENV=production node dist/runtime/server.main.js",
    "dev": "npx --yes kill-port 35729 >/dev/null 2>&1; concurrently --kill-others \"livereload src --exts html,css,ts --wait 500\" \"node scripts/build-client-bundles.js --watch\" \"LIVERELOAD=true tsx watch src/runtime/server.main.ts\"",
    "dev:lambda": "tsx watch src/runtime/lambda.main.ts",
    "permalink": "tsx src/runtime/web/pages/save/save-permalink.cli.main.ts",
    "backfill-registered-at": "tsx src/runtime/providers/auth/backfill-registered-at.cli.main.ts",
    "send-checkout-recovery-emails": "tsx src/runtime/checkout-recovery/send-checkout-recovery-emails.cli.main.ts",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000",
    "test:sequential": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000 --runInBand",
    "test-integration": "jest --testMatch='**/dist/**/*.integration.js' --testTimeout=30000",
    "test-integration:sequential": "jest --testMatch='**/dist/**/*.integration.js' --testTimeout=30000 --runInBand",
    "test:e2e": "pnpm compile && E2E_PORT=3100 playwright test --config playwright.config.local-dev.ts",
    "test:e2e:staging": "playwright test --config playwright.config.staging.ts",
    "test-with-coverage": "c8 node scripts/run-tests-with-coverage.js && node enforce-coverage.config.js",
    "compile": "rm -rf dist && tsc && node scripts/build-client-bundles.js && node scripts/copy-static-assets.js",
    "check-unused-css": "node scripts/check-unused-css.js",
    "lint": "tsc --project tsconfig.lint.json && concurrently --kill-others-on-fail \"biome lint src\" \"knip\" \"pnpm check-unused-css\"",
    "check-infra": "PULUMI_CONFIG_PASSPHRASE='' pulumi preview --stack \"${PULUMI_STACK:?PULUMI_STACK is not set}\"",
    "check": "nx run hutch:check",
    "deploy-infra": "nx run deploy-infra",
    "post-deploy": "nx run post-deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1001.0",
    "@aws-sdk/s3-request-presigner": "3.1001.0",
    "@mozilla/readability": "0.6.0",
    "@node-oauth/express-oauth-server": "4.1.5",
    "@node-oauth/oauth2-server": "5.2.1",
    "@packages/article-resource-unique-id": "workspace:*",
    "@packages/article-state-types": "workspace:*",
    "@packages/crawl-article": "workspace:*",
    "@packages/hutch-infra-components": "workspace:*",
    "@packages/hutch-logger": "workspace:*",
    "@packages/hutch-storage-client": "workspace:*",
    "@packages/onboarding-extension-signal": "workspace:*",
    "@types/parse-srcset": "1.0.0",
    "browser-extension-core": "workspace:*",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "express": "4.22.1",
    "gray-matter": "4.0.3",
    "handlebars": "4.7.8",
    "helmet": "8.1.0",
    "isbot": "5.1.39",
    "linkedom": "0.18.12",
    "markdown-it": "14.1.1",
    "parse-srcset": "1.0.2",
    "resend": "6.9.3",
    "save-link": "workspace:*",
    "serverless-http": "4.0.0",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudfront": "3.1001.0",
    "@packages/check-unused-css": "workspace:*",
    "@packages/test-phase-runner": "workspace:*",
    "@playwright/test": "1.58.2",
    "@pulumi/aws": "7.20.0",
    "@pulumi/pulumi": "3.224.0",
    "@testing-library/dom": "10",
    "@types/aws-lambda": "8.10.161",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "4.17.25",
    "@types/jest": "29.5.14",
    "@types/jsdom": "21.1.7",
    "@types/markdown-it": "14.1.2",
    "@types/node": "22.15.21",
    "@types/supertest": "6.0.3",
    "c8": "10.1.3",
    "concurrently": "9.2.1",
    "esbuild": "0.27.3",
    "jest": "29.7.0",
    "jsdom": "25.0.1",
    "livereload": "0.10.3",
    "supertest": "7.1.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
