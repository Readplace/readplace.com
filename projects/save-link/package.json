{
  "name": "save-link",
  "version": "1.0.0",
  "description": "Event handlers for link saving and summary generation",
  "main": "src/infra/index.ts",
  "private": true,
  "exports": {
    "./save-link": {
      "types": "./dist/runtime/domain/save-link/index.d.ts",
      "default": "./dist/runtime/domain/save-link/index.js"
    },
    "./generate-summary": {
      "types": "./dist/runtime/domain/generate-summary/index.d.ts",
      "default": "./dist/runtime/domain/generate-summary/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "save-link": [
        "./dist/runtime/domain/save-link/index.d.ts"
      ],
      "generate-summary": [
        "./dist/runtime/domain/generate-summary/index.d.ts"
      ]
    }
  },
  "scripts": {
    "compile": "rm -rf dist && tsc && node scripts/copy-static-assets.js",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000",
    "test-with-coverage": "c8 node scripts/run-tests-with-coverage.js && node enforce-coverage.config.js",
    "lint": "tsc --project tsconfig.lint.json && concurrently --kill-others-on-fail \"biome lint src\" \"knip\"",
    "check-infra": "nx run save-link:build-image && pnpm build-curl-impersonate-layer && PULUMI_CONFIG_PASSPHRASE='' pulumi preview --stack \"${PULUMI_STACK:?PULUMI_STACK is not set}\"",
    "check": "nx run save-link:check",
    "build-image": "node tools/build-image.mjs",
    "build-curl-impersonate-layer": "node tools/build-curl-impersonate-layer.mjs",
    "deploy-infra": "nx run save-link:build-image && pnpm build-curl-impersonate-layer && PULUMI_CONFIG_PASSPHRASE='' pulumi up --stack \"${PULUMI_STACK:?PULUMI_STACK is not set}\" $([ \"$CI\" = true ] && echo --yes)",
    "post-deploy": "echo 'No post-deploy steps'"
  },
  "dependencies": {
    "@11ty/posthtml-urls": "1.0.3",
    "@aws-sdk/client-lambda": "3.1001.0",
    "@aws-sdk/client-s3": "3.1001.0",
    "@aws-sdk/client-sqs": "3.1001.0",
    "@packages/article-parser": "workspace:*",
    "@packages/article-resource-unique-id": "workspace:*",
    "@packages/article-state-types": "workspace:*",
    "@packages/article-store": "workspace:*",
    "@packages/crawl-article": "workspace:*",
    "@packages/domain": "workspace:*",
    "@packages/hutch-infra-components": "workspace:*",
    "@packages/hutch-logger": "workspace:*",
    "@packages/hutch-storage-client": "workspace:*",
    "@packages/refresh-article-content": "workspace:*",
    "@packages/retriable": "workspace:*",
    "@packages/test-fixtures": "workspace:*",
    "@smithy/node-http-handler": "4.7.3",
    "@types/parse-srcset": "1.0.0",
    "linkedom": "0.18.12",
    "openai": "6.33.0",
    "parse-srcset": "1.0.2",
    "posthtml": "0.16.7",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@packages/test-phase-runner": "workspace:*",
    "@pulumi/aws": "7.20.0",
    "@pulumi/pulumi": "3.224.0",
    "@types/aws-lambda": "8.10.161",
    "@types/jest": "29.5.14",
    "c8": "10.1.3",
    "concurrently": "9.2.1",
    "esbuild": "0.25.4",
    "jest": "29.7.0",
    "typescript": "5.9.3"
  }
}
