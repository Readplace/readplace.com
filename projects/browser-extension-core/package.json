{
  "name": "browser-extension-core",
  "version": "1.0.0",
  "description": "Browser-agnostic core logic for Readplace browser extensions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./build": {
      "types": "./dist/build/index.d.ts",
      "default": "./dist/build/index.js"
    },
    "./e2e": {
      "types": "./dist/e2e/index.d.ts",
      "default": "./dist/e2e/index.js"
    },
    "./s3-config": {
      "types": "./dist/s3-config.d.ts",
      "default": "./dist/s3-config.js"
    },
    "./e2e-actions": {
      "types": "./dist/e2e-actions/index.d.ts",
      "default": "./dist/e2e-actions/index.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "e2e": ["dist/e2e/index.d.ts"],
      "s3-config": ["dist/s3-config.d.ts"],
      "e2e-actions": ["dist/e2e-actions/index.d.ts"]
    }
  },
  "private": true,
  "scripts": {
    "compile": "tsc",
    "check-unused-css": "node scripts/check-unused-css.js",
    "lint": "tsc --project tsconfig.lint.json && concurrently --kill-others-on-fail \"biome lint src\" \"knip\" \"pnpm check-unused-css\"",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000",
    "test:sequential": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000 --runInBand",
    "test-with-coverage": "c8 node scripts/run-tests-with-coverage.js && node enforce-coverage.config.js",
    "check": "nx run browser-extension-core:check",
    "check-infra": "echo 'No infrastructure — shared library'"
  },
  "dependencies": {
    "@packages/hutch-logger": "workspace:*",
    "esbuild": "0.25.4",
    "js-base64": "3.7.8",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@packages/check-unused-css": "workspace:*",
    "@packages/test-phase-runner": "workspace:*",
    "@types/selenium-webdriver": "4.35.6",
    "c8": "10.1.3",
    "concurrently": "10.0.0",
    "jest": "29.7.0",
    "selenium-webdriver": "4.44.0",
    "typescript": "5.9.3"
  }
}
