{
  "name": "hutch-app-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Readplace monorepo — read-it-later app",
  "scripts": {
    "test": "NX_TUI=true nx run-many --target=test --all",
    "compile": "NX_TUI=true nx run-many --target=compile --all",
    "lint": "NX_TUI=true nx run-many --target=lint --all",
    "dev": "nx run hutch:dev",
    "permalink": "pnpm --filter hutch permalink",
    "check": ". ./.envrc && NX_TUI=true nx run-many --target=check --all",
    "check-infra": "NX_TUI=true nx run-many --target=check-infra --all",
    "deploy-infra": "NX_TUI=true nx run-many --target=deploy-infra --all",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/jest": "29.5.14",
    "@types/node": "22.19.19",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "knip": "5.85.0",
    "minimatch": "10.2.5",
    "nx": "21.6.10",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": ["current", "linux"],
      "cpu": ["current", "x64"],
      "libc": ["current", "glibc"]
    }
  }
}
