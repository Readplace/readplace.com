{
  "name": "@packages/app",
  "version": "1.0.0",
  "description": "Express composition factory (createApp) and test-app fixture wrapper for Readplace",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./test-app": {
      "types": "./dist/test-app.d.ts",
      "default": "./dist/test-app.js"
    },
    "./providers/stripe-checkout/stripe-trial-config": {
      "types": "./dist/providers/stripe-checkout/stripe-trial-config.d.ts",
      "default": "./dist/providers/stripe-checkout/stripe-trial-config.js"
    },
    "./web/*": {
      "types": "./dist/web/*.d.ts",
      "default": "./dist/web/*.js"
    },
    "./client-dist/*": "./dist/web/client-dist/*"
  },
  "typesVersions": {
    "*": {
      "test-app": ["./dist/test-app.d.ts"],
      "providers/stripe-checkout/stripe-trial-config": ["./dist/providers/stripe-checkout/stripe-trial-config.d.ts"],
      "web/*": ["./dist/web/*.d.ts"]
    }
  },
  "private": true,
  "scripts": {
    "compile": "rm -rf dist && tsc && node scripts/build-client-bundles.js && node scripts/copy-static-assets.js",
    "check-unused-css": "node scripts/check-unused-css.js",
    "lint": "tsc --project tsconfig.lint.json && concurrently --kill-others-on-fail \"biome lint src\" \"knip\" \"pnpm check-unused-css\"",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000",
    "test:sequential": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000 --runInBand",
    "test-integration": "jest --testMatch='**/dist/**/*.integration.js' --testTimeout=30000 --passWithNoTests",
    "test-with-coverage": "c8 node scripts/run-tests-with-coverage.js && node enforce-coverage.config.js",
    "permalink": "tsx src/web/pages/save/save-permalink.cli.main.ts",
    "check": "nx run @packages/app:check",
    "check-infra": "echo 'No infrastructure — shared library'"
  },
  "dependencies": {
    "@node-oauth/express-oauth-server": "4.1.5",
    "@node-oauth/oauth2-server": "5.2.1",
    "@packages/article-resource-unique-id": "workspace:*",
    "@packages/crawl-article": "workspace:*",
    "@packages/domain": "workspace:*",
    "@packages/article-state-types": "workspace:*",
    "@packages/hutch-infra-components": "workspace:*",
    "@packages/hutch-logger": "workspace:*",
    "@packages/onboarding-extension-signal": "workspace:*",
    "@packages/test-fixtures": "workspace:*",
    "browser-extension-core": "workspace:*",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "express": "4.22.1",
    "gray-matter": "4.0.3",
    "handlebars": "4.7.8",
    "helmet": "8.1.0",
    "linkedom": "0.18.12",
    "markdown-it": "14.1.1",
    "save-link": "workspace:*",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@packages/check-unused-css": "workspace:*",
    "@packages/test-phase-runner": "workspace:*",
    "@testing-library/dom": "10",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "4.17.25",
    "@types/jest": "29.5.14",
    "@types/jsdom": "21.1.7",
    "@types/markdown-it": "14.1.2",
    "@types/node": "22.15.21",
    "@types/supertest": "6.0.3",
    "c8": "10.1.3",
    "concurrently": "9.2.1",
    "esbuild": "0.27.3",
    "jest": "29.7.0",
    "jsdom": "25.0.1",
    "supertest": "7.1.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
