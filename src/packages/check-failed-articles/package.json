{
  "name": "@packages/check-failed-articles",
  "version": "1.0.0",
  "description": "Read-only DDB scan canary that surfaces articles whose state machines reached a terminal but unsuccessful state (crawl failed/unsupported, summary failed/skipped) so the operator can debug each one",
  "main": "dist/scripts/check-failed-articles.js",
  "private": true,
  "scripts": {
    "compile": "tsc",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint scripts\" \"knip\"",
    "test": "node --test dist/scripts/collect-failed-rows.test.js dist/scripts/exclude-patterns.test.js",
    "check": "pnpm lint && pnpm test",
    "check-infra": "echo 'No infrastructure — canary script'"
  },
  "dependencies": {
    "@packages/article-state-types": "workspace:*",
    "@packages/hutch-storage-client": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "concurrently": "10.0.0",
    "typescript": "5.9.3"
  }
}
