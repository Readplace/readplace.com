{
  "name": "@packages/refresh-article-content",
  "version": "1.0.0",
  "description": "Shared publisher for RefreshArticleContentCommand: stages HTML in S3 then emits the EventBridge event without the body, so hutch (sync) and save-link (async) produce the same wire format.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "compile": "tsc",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint src\" \"knip\"",
    "test": "jest --testMatch='**/dist/**/*.test.js'",
    "test-with-coverage": "c8 pnpm test && node enforce-coverage.config.js",
    "check": "pnpm lint",
    "check-infra": "echo 'No infrastructure — shared library'"
  },
  "dependencies": {
    "@packages/article-resource-unique-id": "workspace:*",
    "@packages/hutch-infra-components": "workspace:*",
    "@packages/test-fixtures": "workspace:*"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "3.1001.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.1001.0",
    "@types/jest": "29.5.14",
    "c8": "10.1.3",
    "concurrently": "9.2.1",
    "jest": "29.7.0",
    "typescript": "5.9.3"
  }
}
