{
  "name": "@packages/domain",
  "version": "1.0.0",
  "description": "Shared domain types, schemas, and pure-domain logic for Readplace",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./article": {
      "types": "./dist/article/index.d.ts",
      "default": "./dist/article/index.js"
    },
    "./article-aggregate": {
      "types": "./dist/article-aggregate/index.d.ts",
      "default": "./dist/article-aggregate/index.js"
    },
    "./user": {
      "types": "./dist/user/index.d.ts",
      "default": "./dist/user/index.js"
    },
    "./oauth": {
      "types": "./dist/oauth/index.d.ts",
      "default": "./dist/oauth/index.js"
    },
    "./import-session": {
      "types": "./dist/import-session/index.d.ts",
      "default": "./dist/import-session/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "article": ["./dist/article/index.d.ts"],
      "article-aggregate": ["./dist/article-aggregate/index.d.ts"],
      "user": ["./dist/user/index.d.ts"],
      "oauth": ["./dist/oauth/index.d.ts"],
      "import-session": ["./dist/import-session/index.d.ts"]
    }
  },
  "private": true,
  "scripts": {
    "compile": "tsc",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint src\" \"knip\"",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000",
    "test-with-coverage": "c8 pnpm test && node enforce-coverage.config.js",
    "check": "nx run @packages/domain:check",
    "check-infra": "echo 'No infrastructure — shared library'"
  },
  "dependencies": {
    "@packages/article-resource-unique-id": "workspace:*",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "c8": "10.1.3",
    "concurrently": "9.2.1",
    "jest": "29.7.0",
    "typescript": "5.9.3"
  }
}
