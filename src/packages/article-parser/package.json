{
  "name": "@packages/article-parser",
  "version": "1.0.0",
  "description": "Article HTML parsers (Readability + site-specific pre-parsers) shared between save-link and hutch",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "compile": "tsc && node scripts/copy-static-assets.js",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint src\" \"knip\"",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000",
    "test-with-coverage": "c8 pnpm test && node enforce-coverage.config.js",
    "check": "pnpm lint && pnpm test-with-coverage",
    "check-infra": "echo 'No infrastructure — shared library'"
  },
  "dependencies": {
    "@mozilla/readability": "0.6.0",
    "@packages/crawl-article": "workspace:*",
    "linkedom": "0.18.12",
    "parse-srcset": "1.0.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/parse-srcset": "1.0.0",
    "c8": "10.1.3",
    "concurrently": "10.0.0",
    "jest": "29.7.0",
    "typescript": "5.9.3"
  }
}
