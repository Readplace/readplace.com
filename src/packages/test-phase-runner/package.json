{
  "name": "@packages/test-phase-runner",
  "version": "1.0.0",
  "description": "Reusable test phase runner for coverage-instrumented test suites",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "compile": "tsc",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint src\" \"knip\"",
    "test": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000",
    "test-with-coverage": "c8 pnpm test && node enforce-coverage.config.js",
    "test:sequential": "jest --testMatch='**/dist/**/*.test.js' --testTimeout=10000 --runInBand",
    "check": "nx run @packages/test-phase-runner:check",
    "check-infra": "echo 'No infrastructure — shared library'"
  },
  "devDependencies": {
    "c8": "10.1.3",
    "concurrently": "10.0.0",
    "jest": "29.7.0",
    "typescript": "5.9.3"
  }
}
