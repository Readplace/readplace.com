{
  "name": "@packages/crawl-article",
  "version": "1.0.0",
  "description": "Article crawler with browser-like headers for Fastly/Cloudflare edge sniffers; owns its own real-network canary",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "private": true,
  "scripts": {
    "compile": "rm -rf dist && tsc",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint src scripts\" \"knip\"",
    "test": "jest --testMatch='**/dist/src/**/*.test.js'",
    "test-with-coverage": "c8 pnpm test && node enforce-coverage.config.js",
    "check": "pnpm lint",
    "check-infra": "echo 'No infrastructure — shared library'"
  },
  "dependencies": {
    "@packages/article-state-types": "workspace:*",
    "@packages/hutch-logger": "workspace:*",
    "escape-html": "1.0.3",
    "linkedom": "0.18.12"
  },
  "devDependencies": {
    "@types/escape-html": "1.0.4",
    "@types/jest": "29.5.14",
    "c8": "10.1.3",
    "concurrently": "9.2.1",
    "jest": "29.7.0",
    "typescript": "5.9.3"
  }
}
