{
  "name": "@packages/hutch-storage-client",
  "version": "1.0.0",
  "description": "DynamoDB gateway — the only module allowed to import @aws-sdk/lib-dynamodb. Forces schema-driven null handling on every row.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "private": true,
  "scripts": {
    "compile": "tsc",
    "lint": "concurrently --kill-others-on-fail \"tsc --project tsconfig.lint.json\" \"biome lint src\" \"knip\"",
    "test": "echo 'No testable logic — thin wrapper over AWS SDK, tested via consumers'",
    "check": "pnpm lint",
    "check-infra": "echo 'No infrastructure — shared library'"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.1057.0",
    "@aws-sdk/lib-dynamodb": "3.1057.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "concurrently": "10.0.0",
    "typescript": "5.9.3"
  }
}
